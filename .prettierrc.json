{
  "plugins": ["prettier-plugin-django-alpine"],
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "htmlWhitespaceSensitivity": "ignore",
  "overrides": [
    {
      "files": ["**/templates/**/*.html", "**/templates/**/*.txt"],
      "options": {
        "parser": "html"
      }
    }
  ]
}
